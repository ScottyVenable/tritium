{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tritium://schemas/email.json",
  "title": "Tritium email message",
  "type": "object",
  "required": ["from", "to", "subject", "body"],
  "properties": {
    "from":    { "type": "string", "minLength": 1, "maxLength": 64 },
    "to":      { "type": "string", "minLength": 1, "maxLength": 64 },
    "subject": { "type": "string", "minLength": 1, "maxLength": 300 },
    "body":    { "type": "string", "minLength": 1, "maxLength": 200000 },
    "attachments": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["kind", "name", "ref"],
        "properties": {
          "kind": { "enum": ["path", "inline"] },
          "name": { "type": "string", "maxLength": 200 },
          "ref":  { "type": "string", "maxLength": 100000, "description": "Filesystem path (kind=path) or inline UTF-8 blob (kind=inline)." }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
