# Build artifacts
dist/

# Runtime caches
.tritium/
.tritium-verify/

# Node
node_modules/

# Backups created by install.sh
*.bak

# Local SETTINGS overrides (the example file IS committed)
SETTINGS.jsonc

# -- Tritium OS v4.1 crypt boundary (DO NOT REMOVE) ----------------------
.tritium_mirror/
world_vault/*.plain
world_vault/*.tmp
**/*.x25519
**/*.ed25519
**/*.pem
**/*.key
*.enc.tmp
*.json.tmp

# Tritium home (keys, ledger, state -- never committed)
.tritium-os/

# Python cache
__pycache__/
*.pyc
*.pyo
.pytest_cache/
